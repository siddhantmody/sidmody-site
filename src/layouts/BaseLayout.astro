---
// BaseLayout.astro — wraps every page
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = "siddhant mody — meche + robotics m.s. @ penn", wide = false } = Astro.props;
const path = Astro.url.pathname;
function isCurrent(p: string) {
  if (p === '/' && (path === '/' || path === '')) return true;
  return path.startsWith(p) && p !== '/';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {/* Critical inline CSS: theme variables apply immediately, before the
        external stylesheet loads. Prevents flash of unstyled content on
        navigation between pages. */}
    <style is:inline>
      :root, :root[data-theme="light"] {
        --bg: #f4f1ea;
        --fg: #1a1a1a;
      }
      :root[data-theme="dark"] {
        --bg: #1c1c1e;
        --fg: #ece7dd;
      }
      html { background: var(--bg); color: var(--fg); }
    </style>
    {/* Set theme before paint to prevent flash of wrong theme.
        Reads explicit user choice from localStorage; falls back to system. */}
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored
            ? stored
            : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header fade-in fade-in--1">
      <a href="/" class="site-header__name">siddhant mody</a>
      <nav class="site-header__nav" aria-label="primary">
        <a href="/" aria-current={isCurrent('/') ? 'page' : undefined}>home</a>
        <a href="/about/" aria-current={isCurrent('/about') ? 'page' : undefined}>about</a>
        <a href="/projects/" aria-current={isCurrent('/projects') ? 'page' : undefined}>projects</a>
        <a href="/blog/" aria-current={isCurrent('/blog') ? 'page' : undefined}>writing</a>
        <button
          type="button"
          class="theme-toggle"
          id="theme-toggle"
          aria-label="toggle color theme"
          title="toggle color theme"
        >
          {/* Moon icon — shown in light mode (click to go dark) */}
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
          {/* Sun icon — shown in dark mode (click to go light) */}
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <line x1="12" y1="2" x2="12" y2="5" />
            <line x1="12" y1="19" x2="12" y2="22" />
            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34" />
            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78" />
            <line x1="2" y1="12" x2="5" y2="12" />
            <line x1="19" y1="12" x2="22" y2="12" />
            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66" />
            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22" />
          </svg>
        </button>
      </nav>
    </header>

    <main class={`page ${wide ? 'page--wide' : ''}`}>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© 2026 siddhant mody</span>
      <div class="site-footer__links">
        <a href="mailto:sidmody@seas.upenn.edu">email</a>
        <a href="https://www.linkedin.com/in/siddhant-mody/" target="_blank" rel="noopener">linkedin</a>
        <a href="https://github.com/siddhantmody" target="_blank" rel="noopener">github</a>
      </div>
    </footer>

    {/* Toggle handler + sync with system preference for users who haven't explicitly chosen */}
    <script is:inline>
      (function() {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });

        // If user hasn't made an explicit choice, follow system changes live.
        try {
          var mq = window.matchMedia('(prefers-color-scheme: dark)');
          mq.addEventListener('change', function(e) {
            if (!localStorage.getItem('theme')) {
              document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
            }
          });
        } catch (e) {}
      })();
    </script>
  </body>
</html>